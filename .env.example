# ─── Base de données ──────────────────────────────────────────────────────────
POSTGRES_USER=it_pm_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=it_project_manager

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Générer avec : node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_SECRET=change_me_jwt_secret_64chars_minimum
JWT_REFRESH_SECRET=change_me_refresh_secret_64chars_minimum
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production

# URL du frontend (pour CORS) — ex: http://mon-serveur.local ou https://pm.mondomaine.fr
FRONTEND_URL=http://localhost

# Port exposé pour le frontend (80 par défaut)
FRONTEND_PORT=80

# ─── Compte admin initial (seed au premier démarrage) ─────────────────────────
SEED_ADMIN_EMAIL=admin@it-pm.local
SEED_ADMIN_PASSWORD=Admin1234!
SEED_ADMIN_NOM=Administrateur
